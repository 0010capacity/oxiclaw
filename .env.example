# ============================================
# Telegram
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ============================================
# LLM Providers (pi-mono AuthStorage)
# ============================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ZAI_API_KEY=
MINIMAX_API_KEY=

# ============================================
# Spotify OAuth
# ============================================
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_TOKENS_DIR=/app/secrets/spotify

# ============================================
# MCP Servers (optional)
# Format: JSON object with server name as key and command as value
# Example: {"filesystem":"npx -y @modelcontextprotocol/server-filesystem /workspace"}
# ============================================
MCP_SERVERS=

# ============================================
# pi-mono Configuration
# ============================================
PI_MONO_CONTAINER_IMAGE=mariozechner/pi-coding-agent:latest

# ============================================
# Extension Settings
# ============================================
ENABLE_TELEGRAM_NATIVE=true
ENABLE_MULTIMODAL=true

# ============================================
# Zai Image Generation
# ============================================
ZAI_IMAGE_SIZE=1024x1024
ZAI_IMAGE_COUNT=1

# ============================================
# TTS Settings
# ============================================
TTS_DEFAULT_VOICE=alloy
TTS_DEFAULT_PROVIDER=zai

# ============================================
# Container Settings
# ============================================
CONTAINER_NETWORK=oxiclaw-net
MAX_CONCURRENT_CONTAINERS=10